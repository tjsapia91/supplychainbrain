# Windows
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# Mac
.DS_Store
.AppleDouble
.LSOverride

# Office temp files (Excel, Word, PowerPoint)
~$*
*.tmp

# Large binary files (keep attachments local unless small)
*.xlsx
*.xls
*.pdf
*.zip
*.7z

# Python / scripts
__pycache__/
*.pyc
.env

# Node (if any tools get built)
node_modules/

# Code repositories — keep code in its own repo, not in the vault
erp_system/
*.zip
*.tar.gz

# Obsidian Claudian internal files
.claudian/

# Generated reports — copies of MTB-SupplyChain outputs, regenerated weekly
outputs/

# Windows directory junction → OneDrive\SupplyChain1\SupplyChainClaude
# (operational briefs, deep-dives, runbooks). Files live in OneDrive; vault
# gets a live mount via Junction. Don't commit copies of cloud-sync'd files.
10 System/SupplyChainClaude/

# Backup files — git history is the backup
*.backup_*
